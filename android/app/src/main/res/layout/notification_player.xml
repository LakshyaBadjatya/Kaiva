<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@android:color/transparent">

    <!-- Album art -->
    <ImageView
        android:id="@+id/notif_album_art"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:contentDescription="Album art" />

    <!-- Title / artist + waveform -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notif_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#B3FFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="1dp" />

        <!-- Progress bar + waveform row -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginTop="6dp">

            <!-- Standard seek-bar (always visible, shows full track) -->
            <ProgressBar
                android:id="@+id/notif_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="center_vertical"
                android:progressTint="#80EF9F27"
                android:progressBackgroundTint="#33FFFFFF"
                android:max="1000" />

            <!-- Waveform — frame-swapped by WaveformNotificationManager each 150ms -->
            <ImageView
                android:id="@+id/notif_waveform"
                android:layout_width="44dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:src="@drawable/eq_frame0"
                android:visibility="invisible" />

        </FrameLayout>

    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/notif_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_skip_previous"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous"
            android:tint="#FFFFFFFF" />

        <ImageButton
            android:id="@+id/notif_play_pause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:src="@drawable/ic_pause"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play/Pause"
            android:tint="#FFFFFFFF" />

        <ImageButton
            android:id="@+id/notif_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_skip_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next"
            android:tint="#FFFFFFFF" />

    </LinearLayout>

</LinearLayout>
